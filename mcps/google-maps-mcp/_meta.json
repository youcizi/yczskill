{
  "id": "google-maps-mcp",
  "name": "Google Maps 搜索",
  "description": "通过 MCP 协议直接调用地图数据进行位置搜索与分析",
  "author": "MCP Community",
  "mcp_config": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-google-maps"],
    "env": {
      "GOOGLE_MAPS_API_KEY": "YOUR_API_KEY_HERE"
    }
  }
}
