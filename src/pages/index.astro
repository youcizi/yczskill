---
import BaseLayout from '../layouts/BaseLayout.astro';
import MarketCard from '../components/MarketCard.astro';
import skillsMaster from '../data/skills-master.json';
import mcpsMaster from '../data/mcps-master.json';
import { Icon } from 'astro-icon/components';

const skills = skillsMaster || [];
const mcps = mcpsMaster || [];
const total = skills.length + mcps.length;
---

<BaseLayout 
	title="装配工厂 | 数字员工技能商店 & MCP 服务市场" 
	description="发现、下载和安装 AI 智能体技能与 MCP 扩展插件。"
	lang="zh"
>
	<header class="hero-section glass" slot="header">
		<nav class="nav-container container">
			<div class="logo">
				<Icon name="lucide:zap" class="logo-icon" />
				<span>装配工厂 <span>Factory</span></span>
			</div>
			<div class="nav-actions">
				<a href="/en" class="lang-toggle btn-ghost">
					<Icon name="lucide:languages" />
					English
				</a>
				<button id="copy-repo" class="btn-primary">
					<Icon name="lucide:copy" />
					复制仓库地址
				</button>
			</div>
		</nav>

		<div class="hero-content container">
			<div class="badge animate-fade-in">Astro + Cloudflare Pages</div>
			<h1 class="animate-fade-in">数字员工<span>技能商店</span></h1>
			<p class="subtitle animate-fade-in">以 Skill 商店与 MCP 服务为核心，构建您的 AI 能力库</p>
			
			<div class="search-area animate-fade-in">
				<div class="search-box glass">
					<Icon name="lucide:search" class="search-icon" />
					<input type="text" id="search-input" placeholder="搜索资源库 (按 / 聚焦)..." />
					<kbd>/</kbd>
				</div>
			</div>
		</div>
	</header>

	<main class="container main-content">
		<div class="sticky-bar glass">
			<div class="tabs" id="tab-switcher">
				<button class="tab-btn active" data-tab="all">
					全部资源
					<span class="count">{total}</span>
				</button>
				<button class="tab-btn" data-tab="skill">
					技能包 (Skills)
					<span class="count">{skills.length}</span>
				</button>
				<button class="tab-btn" data-tab="mcp">
					工具 (MCP)
					<span class="count">{mcps.length}</span>
				</button>
			</div>
		</div>

		<section class="grid-section" id="resource-grid">
			{skills.map(item => <MarketCard item={item} lang="zh" />)}
			{mcps.map(item => <MarketCard item={item} lang="zh" />)}
		</section>
	</main>

	<footer class="container footer glass" slot="footer">
		<div class="footer-grid">
			<div class="footer-info">
				<h4>关于装配工厂</h4>
				<p>我们提供工程化、标准化的 AI 技能分发服务。</p>
			</div>
			<div class="footer-links">
				<h4>开放接口</h4>
				<a href="/api/search.json" target="_blank">Search API</a>
				<a href="/api/skills/1.json" target="_blank">Skill Registry</a>
				<a href="/api/mcps/1.json" target="_blank">MCP Registry</a>
			</div>
		</div>
		<div class="copyright">
			© 2026 AI Factory. Powered by Astro & Cloudflare.
		</div>
	</footer>
</BaseLayout>

<style>
	.container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
	
	.hero-section {
		padding: 2rem 0 6rem;
		background: radial-gradient(circle at top right, var(--primary-glow), transparent),
					radial-gradient(circle at bottom left, rgba(16, 185, 129, 0.1), transparent);
		margin-bottom: -3rem;
	}

	.nav-container {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-bottom: 4rem;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-family: 'Outfit', sans-serif;
		font-weight: 800;
		font-size: 1.5rem;
	}
	.logo span span { opacity: 0.5; font-weight: 400; font-size: 1.2rem; }
	.logo-icon { color: var(--primary); }

	.nav-actions { display: flex; gap: 1rem; }

	.btn-primary {
		background: var(--primary);
		color: white;
		border: none;
		padding: 0.6rem 1.2rem;
		border-radius: 0.75rem;
		font-weight: 600;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		cursor: pointer;
		transition: all 0.2s;
	}
	.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 15px -3px var(--primary-glow); }

	.btn-ghost {
		background: transparent;
		color: var(--text);
		border: 1px solid var(--border);
		padding: 0.6rem 1.2rem;
		border-radius: 0.75rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		font-size: 0.9rem;
	}

	.hero-content { text-align: center; }
	.badge {
		display: inline-block;
		padding: 0.3rem 1rem;
		background: rgba(99, 102, 241, 0.1);
		border: 1px solid var(--primary);
		border-radius: 9999px;
		color: var(--primary);
		font-size: 0.8rem;
		font-weight: 700;
		margin-bottom: 2rem;
	}
	h1 {
		font-family: 'Outfit', sans-serif;
		font-size: 4rem;
		font-weight: 800;
		margin-bottom: 1.5rem;
		letter-spacing: -0.03em;
		line-height: 1;
	}
	h1 span { display: block; background: linear-gradient(90deg, #818cf8, #34d399); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
	.subtitle { font-size: 1.25rem; color: var(--text-muted); margin-bottom: 3rem; }

	.search-area { max-width: 700px; margin: 0 auto; }
	.search-box {
		padding: 0.5rem 1rem;
		border-radius: 1.25rem;
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.search-icon { color: var(--text-muted); width: 24px; }
	#search-input {
		background: transparent;
		border: none;
		color: var(--text);
		width: 100%;
		padding: 0.75rem 0;
		font-size: 1.1rem;
		outline: none;
	}
	kbd {
		background: var(--border);
		padding: 0.2rem 0.5rem;
		border-radius: 0.4rem;
		font-size: 0.7rem;
		color: var(--text-muted);
	}

	.main-content { padding-top: 5rem; }
	.sticky-bar {
		position: sticky;
		top: 1.5rem;
		z-index: 50;
		padding: 0.75rem;
		border-radius: 1.25rem;
		display: flex;
		justify-content: center;
		margin-bottom: 4rem;
	}

	.tabs { display: flex; gap: 0.5rem; }
	.tab-btn {
		padding: 0.5rem 1.25rem;
		border-radius: 0.75rem;
		background: transparent;
		border: none;
		color: var(--text-muted);
		font-weight: 600;
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		transition: all 0.2s;
	}
	.tab-btn.active { background: var(--border); color: var(--text); }
	.tab-btn .count { background: #1f2937; padding: 0.1rem 0.4rem; border-radius: 0.4rem; font-size: 0.7rem; }

	.grid-section {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
		gap: 2.5rem;
		padding-bottom: 6rem;
	}

	.footer {
		margin-top: 4rem;
		padding: 4rem 2rem 2rem;
		border-radius: 2rem 2rem 0 0;
		border-bottom: none;
	}
	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 4rem;
		margin-bottom: 4rem;
	}
	.footer-info h4, .footer-links h4 { font-family: 'Outfit', sans-serif; margin-bottom: 1.5rem; color: var(--text); }
	.footer-info p { color: var(--text-muted); }
	.footer-links { display: flex; flex-direction: column; gap: 0.75rem; }
	.footer-links a { color: var(--text-muted); text-decoration: none; font-size: 0.9rem; }
	.footer-links a:hover { color: var(--primary); }
	.copyright { text-align: center; font-size: 0.8rem; color: #4b5563; padding-top: 2rem; border-top: 1px solid var(--border); }
</style>

<script>
	// Tab Filtering
	const tabBtns = document.querySelectorAll('.tab-btn');
	const cards = document.querySelectorAll('.card');

	tabBtns.forEach(btn => {
		btn.addEventListener('click', () => {
			const tab = btn.getAttribute('data-tab');
			tabBtns.forEach(b => b.classList.remove('active'));
			btn.classList.add('active');

			cards.forEach(card => {
				const type = (card as HTMLElement).dataset.type;
				if (tab === 'all' || type === tab) {
					(card as HTMLElement).style.display = 'flex';
				} else {
					(card as HTMLElement).style.display = 'none';
				}
			});
		});
	});

	// Global Search
	const searchInput = document.getElementById('search-input') as HTMLInputElement;
	searchInput?.addEventListener('input', (e) => {
		const term = (e.target as HTMLInputElement).value.toLowerCase();
		cards.forEach(card => {
			const name = (card as HTMLElement).dataset.name || '';
			const desc = (card as HTMLElement).dataset.desc || '';
			if (name.includes(term) || desc.includes(term)) {
				(card as HTMLElement).style.display = 'flex';
			} else {
				(card as HTMLElement).style.display = 'none';
			}
		});
	});

	// Copy Logic
	document.getElementById('copy-repo')?.addEventListener('click', function() {
		navigator.clipboard.writeText(window.location.origin).then(() => {
			const original = this.innerHTML;
			this.innerHTML = '✅ 已复制';
			setTimeout(() => { this.innerHTML = original; }, 2000);
		});
	});

	// Shortcut
	document.addEventListener('keydown', (e) => {
		if (e.key === '/' && document.activeElement !== searchInput) {
			e.preventDefault();
			searchInput?.focus();
		}
	});

	// Card Copy Logic
	document.querySelectorAll('.copy-tiny').forEach(btn => {
		btn.addEventListener('click', () => {
			const cmd = btn.getAttribute('data-cmd') || '';
			navigator.clipboard.writeText(cmd).then(() => {
				const original = btn.innerHTML;
				btn.innerHTML = '✅';
				setTimeout(() => { btn.innerHTML = original; }, 1500);
			});
		});
	});
</script>
